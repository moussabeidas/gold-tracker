{
  "expo": {
    "name": "Gold Pricer",
    "slug": "gold-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "goldtracker",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "primaryColor": "#FFD700",
    "description": "Track live gold prices and manage your physical gold portfolio. Real-time XAU/USD charts, gain/loss analytics, and camera photo capture for every bar and coin.",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.mbeidas.goldtracker",
      "buildNumber": "33",
      "supportsTablet": false,
      "requireFullScreen": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Gold Tracker uses your camera to photograph your gold bars and coins for your portfolio records.",
        "NSPhotoLibraryUsageDescription": "Gold Tracker accesses your photo library to add images of your gold holdings.",
        "NSPhotoLibraryAddUsageDescription": "Gold Tracker saves photos of your gold holdings to your library."
      },
      "usesAppleSignIn": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.mbeidas.goldtracker"
        ]
      }
    },
    "android": {
      "backgroundColor": "#000000",
      "package": "com.goldtracker.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Gold Tracker accesses your photos to add images of your gold holdings.",
          "cameraPermission": "Gold Tracker uses your camera to photograph your gold bars and coins."
        }
      ],
      "expo-iap",
      [
        "@bacons/apple-targets",
        {
          "appleTeamId": "P2TSL4VJ5H"
        }
      ],
      "expo-notifications",
      "expo-task-manager",
      "expo-background-task"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "8f876a5a-1c87-4419-848c-5d62252c5d06"
      }
    },
    "owner": "mbeidas"
  }
}
